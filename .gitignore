nodes-ros2/superados
.vscode/*
# ==========================================
# Diretórios Autogerados do Workspace ROS 2
# ==========================================
# Estas pastas são criadas pelo 'colcon build' e nunca devem ser versionadas.
build/
install/
log/

# ==========================================
# ROS 2 Bags (Gravações de Tópicos)
# ==========================================
# Arquivos de gravação costumam ser pesados e não devem ir para o repositório.
*.db3
*.mcap
*.bag

# ==========================================
# Python
# ==========================================
_pycache_/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ==========================================
# C++ / CMake
# ==========================================
# O colcon geralmente isola isso na pasta build/, mas é bom garantir.
CMakeCache.txt
CMakeFiles/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json

# ==========================================
# Arquivos de IDE e Sistema Operacional
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db